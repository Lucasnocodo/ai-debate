# LLM API 設定（全部模型都走同一個 proxy）
# GPT / Grok → OpenAI 格式 /v1/chat/completions
# Claude → Anthropic 格式 /v1/messages
# Gemini → Google 格式 /v1beta/models/{model}:generateContent
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.banana2556.com/v1

# 辯論參數（可選）
DEBATE_ROUNDS=30
DEBATE_MAX_TOKENS=1000
